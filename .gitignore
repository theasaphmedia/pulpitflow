# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing — NEVER commit these
android/key.properties
*.jks
*.keystore

android/build/
supabase/.temp/

# Contains BIBLE_API_KEY — never commit. Bundled as a Flutter asset at build
# time; CI (Vercel) writes this file from environment variables instead.
.env
